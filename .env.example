# Optional local environment variables.
# Do not commit a real .env file.

# Hugging Face token, if needed for private or gated models.
HF_TOKEN=

# Disable Weights & Biases in local dashboard-launched runs.
WANDB_DISABLED=true

# Optional service overrides. CLI arguments take precedence.
LOCALTUNE_HOST=127.0.0.1
LOCALTUNE_PORT=6543
LOCALTUNE_TENSORBOARD_PORT=6006

# Optional Vite development proxy target.
VITE_API_TARGET=http://127.0.0.1:6543
